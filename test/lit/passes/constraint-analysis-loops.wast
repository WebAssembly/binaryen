;; NOTE: Assertions have been generated by update_lit_checks.py and should not be edited.

;; RUN: wasm-opt %s --constraint-analysis -all -S -o - | filecheck %s

(module
  (import "a" "b" (func $import (result i32)))

  (func $bound
    (local $x i32)
    (loop $loop
      ;; We arrive at the loop top with {x == 0} or {x > 0 && x <= 100}. Those
      ;; OR into {x >= 0 && x <= 100} - that is, the x == 0 and x > 0 combine
      ;; into x >= 0.
      (drop
        (i32.ge_s
          (local.get $x)
          (i32.const 0)
        )
      )
      (drop
        (i32.le_s
          (local.get $x)
          (i32.const 100)
        )
      )
      ;; Set $x to an unknown value before applying the constraints below on the
      ;; way back to the loop top.
      (local.set $x
        (call $import)
      )
      (if
        (i32.gt_s
          (local.get $x)
          (i32.const 0)
        )
        (then
          (if
            (i32.le_s
              (local.get $x)
              (i32.const 100)
            )
            (then
              (br $loop)
            )
          )
        )
      )
    )
  )
)

  ;; OPTIN-NEXT:    (if
  ;; OPTIN-NEXT:     (i32.eq
  ;; OPTIN-NEXT:      (local.get $y)
  ;; OPTIN-NEXT:      (i32.const 20)
  ;; OPTIN-NEXT:     )
  ;; OPTIN-NEXT:     (then
  ;; OPTIN-NEXT:      (drop
  ;; OPTIN-NEXT:       (i32.const 1)
  ;; OPTIN-NEXT:      )
  ;; OPTIN-NEXT:      (drop
  ;; OPTIN-NEXT:       (i32.const 0)
  ;; OPTIN-NEXT:      )
  ;; OPTIN-NEXT:      (drop
  ;; OPTIN-NEXT:       (i32.const 0)
  ;; OPTIN-NEXT:      )
  ;; OPTIN-NEXT:      (drop

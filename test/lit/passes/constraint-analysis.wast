  (func $local-changes-2 (param $x i32) (param $y i32) (param $z i32)
    ;; As above, but the set in the middle is on y, not x.
    (local.set $x
      (local.get $y)
    )
    ;; x == y but not z, as above.
    (drop
      (i32.eq
        (local.get $x)
        (local.get $y)

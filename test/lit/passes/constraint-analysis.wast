        (local.get $y)
        (local.get $x)
      )
    )
    (drop
      (i32.eq
        (local.get $x)
        (local.get $z)
      )
    )
    (drop
      (i32.eq
        (local.get $z)
        (local.get $x)
      )
    )

    (local.set $y    ;; this changed
      (local.get $z)
    )
    ;; We can prove nothing here.
    (drop
      (i32.eq
        (local.get $x)

  ;; OPTIN-NEXT:  (drop
  ;; OPTIN-NEXT:   (block $block (result (ref any))
  ;; OPTIN-NEXT:    (drop
  ;; OPTIN-NEXT:     (ref.is_null
  ;; OPTIN-NEXT:      (local.get $param)

        (local.get $z)
      )
    )
    (drop
      (i32.eq
        (local.get $z)
        (local.get $x)
      )
    )

    ;; But y == z.
    (drop
      (i32.eq
        (local.get $y)
        (local.get $z)
      )
    )
    (drop
      (i32.eq
        (local.get $z)
        (local.get $y)
      )
    )
  )


  (func $conditional-binary-nesting (param $x i32) (param $y i32)
    (if
      (i32.eq
        (local.get $x)
        (i32.const 10)
      )
      (then
        (if
          (i32.eq
            (local.get $y)
            (i32.const 20)
          )
          (then
            ;; x is 10 here, and y is 20.

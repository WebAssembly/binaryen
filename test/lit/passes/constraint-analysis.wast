  ;; OPTIN-NEXT:     (i32.const 10)
  ;; OPTIN-NEXT:    )
  ;; OPTIN-NEXT:   )
  ;; OPTIN-NEXT:  )
  ;; OPTIN-NEXT:  (drop
  ;; OPTIN-NEXT:   (i32.eq
  ;; OPTIN-NEXT:    (local.get $param)
  ;; OPTIN-NEXT:    (i32.const 10)
  ;; OPTIN-NEXT:   )
  ;; OPTIN-NEXT:  )
  ;; OPTIN-NEXT:  (drop
  ;; OPTIN-NEXT:   (i32.ne
  ;; OPTIN-NEXT:    (local.get $param)

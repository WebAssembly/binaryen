    (data.drop $0)
    (array.init_data $1 $0
      (array.new_data $1 $5
        (i32.const 0)
        (i32.const 0)
      )
      (i32.const 0)
      (i32.const 0)
      (i32.const 0)
    )
    (memory.init $4
      (i32.const 0)
      (i32.const 0)
      (i32.const 0)
    )
    (data.drop $3)
    (array.init_data $1 $2
      (array.new_data $1 $1
        (i32.const 0)

  ;; CHECK-NEXT:  )
  ;; CHECK-NEXT:  (drop
  ;; CHECK-NEXT:   (ref.func $f1)
  ;; CHECK-NEXT:  )
  ;; CHECK-NEXT: )
  (func $test
    (drop (ref.func $f1))
    (drop (ref.func $f2))
    (drop (ref.func $f1))
  )
)

  ;; CHECK-NEXT:  (local $cont (ref null $return-sub-cont))
  ;; CHECK-NEXT:  (drop
  ;; CHECK-NEXT:   (block $l (result (ref null $return-super-cont))
  ;; CHECK-NEXT:    (drop

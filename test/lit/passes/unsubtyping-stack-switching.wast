    (local $cont (ref null $return-sub-cont))
    (drop
      (block $l (result (ref null $return-super-cont))
        (drop
          ;; Same as above, but now the continuation is null so we can optimize.
          (resume $return-sub-cont (on $e $l)
            (ref.null nocont)
          )
        )
        (ref.null nocont)
      )
    )
  )
)


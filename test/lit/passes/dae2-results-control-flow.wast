  ;; CHECK:      (func $caller (type $0)
  ;; CHECK-NEXT:  (global.set $g
  ;; CHECK-NEXT:   (call $test
  ;; CHECK-NEXT:    (i32.const 1)
  ;; CHECK-NEXT:   )
  ;; CHECK-NEXT:  )
  ;; CHECK-NEXT: )
  (func $caller
    ;; Same, but now the result is used.

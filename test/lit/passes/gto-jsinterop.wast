  ;; CHECK:      (export "export" (global $export))

  ;; CHECK:      (func $use-sub (type $3)
  ;; CHECK-NEXT:  (local $0 (ref null $sub))
  ;; CHECK-NEXT: )
  (func $use-sub
    (local (ref null $sub))
  )
)

(module

;; NOTE: Assertions have been generated by update_lit_checks.py and should not be edited.

;; RUN: wasm-opt %s --constraint-analysis -all -S -o - | filecheck %s

(module
 ;; CHECK:      (tag $tag (type $0) (param i32))
 (tag $tag (param i32))

 ;; CHECK:      (func $0 (type $1)
 ;; CHECK-NEXT:  (local $x i32)
 ;; CHECK-NEXT:  (try
 ;; CHECK-NEXT:   (do
 ;; CHECK-NEXT:   )
 ;; CHECK-NEXT:   (catch $tag
 ;; CHECK-NEXT:    (drop
 ;; CHECK-NEXT:     (pop i32)
 ;; CHECK-NEXT:    )
 ;; CHECK-NEXT:    (unreachable)
 ;; CHECK-NEXT:   )
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $0
  (local $x i32)
  (try
   (do
   )
   (catch $tag
    ;; This code is unreachable: no throw exists that can reach it. However, it
    ;; is invalid to remove a pop, as that would not validate, so we keep it.
    (local.set $x
     (pop i32)
    )
   )
  )
 )
)


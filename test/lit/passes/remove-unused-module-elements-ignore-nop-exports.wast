;; NOTE: Assertions have been generated by update_lit_checks.py --all-items and should not be edited.

;; RUN: foreach %s %t wasm-opt --remove-unused-module-elements --pass-arg=remove-unused-module-elements-ignore-nop-exports -all -S -o - | filecheck %s

(module
  ;; A nop exported function: should be removed along with its export.
  (func $nop-exported (export "nop-exported")
    (nop)
  )

  ;; A non-nop exported function: should be kept.
  ;; CHECK:      (type $0 (func))

  ;; CHECK:      (export "real-exported" (func $real-exported))

  ;; CHECK:      (export "caller" (func $caller))

  ;; CHECK:      (func $real-exported (type $0)
  ;; CHECK-NEXT:  (drop
  ;; CHECK-NEXT:   (i32.const 42)
  ;; CHECK-NEXT:  )
  ;; CHECK-NEXT: )
  (func $real-exported (export "real-exported")
    (drop (i32.const 42))
  )

  ;; A nop function that is called internally: should be kept even though it is nop.
  ;; CHECK:      (func $nop-called (type $0)
  ;; CHECK-NEXT:  (nop)
  ;; CHECK-NEXT: )
  (func $nop-called (export "nop-called")
    (nop)
  )

  ;; CHECK:      (func $caller (type $0)
  ;; CHECK-NEXT:  (call $nop-called)
  ;; CHECK-NEXT: )
  (func $caller (export "caller")
    (call $nop-called)
  )
)

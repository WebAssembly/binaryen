;; NOTE: Assertions have been generated by update_lit_checks.py --all-items and should not be edited.

;; RUN: wasm-opt %s -all --optimize-level=3 --generate-stack-ir --optimize-stack-ir --print-stack-ir | filecheck %s

(module
  ;; CHECK:      (type $0 (func (result i32 f64 anyref)))

  ;; CHECK:      (func $multivalue-return (type $0) (result i32 f64 anyref)
  ;; CHECK-NEXT:  (local $temp (tuple i32 f64 anyref))
  ;; CHECK-NEXT:  call $multivalue-return
  ;; CHECK-NEXT:  tuple.make 3
  ;; CHECK-NEXT: )
  (func $multivalue-return (result i32 f64 anyref)
    (local $temp (tuple i32 f64 anyref))
    (tuple.make 3
      (tuple.extract 3 0
        (local.tee $temp
          (call $multivalue-return)
        )
      )
      (tuple.extract 3 1
        (local.get $temp)
      )
      (tuple.extract 3 2
        (local.get $temp)
      )
    )
  )
)

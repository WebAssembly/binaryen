;; NOTE: Assertions have been generated by update_lit_checks.py --all-items and should not be edited.

;; Test trimming of never-called functions from the edges of element segments.

;; RUN: foreach %s %t wasm-opt --remove-unused-module-elements -all -S -o - | filecheck %s

(module
 ;; The only calls are of $live1 and $live2's type, so the other entries can
 ;; never be called successfully. $deadA and $deadB are at the edges of the
 ;; segment, so they can be trimmed from it (bumping the segment's offset for
 ;; the leading one) and their functions removed entirely. $deadMid is in the
 ;; interior, where trimming would leave a hole, so it is kept, but its body
 ;; can be emptied out.
 ;; CHECK:      (type $0 (func (param i32)))

 ;; CHECK:      (type $1 (func (param i64)))

 ;; CHECK:      (table $t 10 10 funcref)
 (table $t 10 10 funcref)

 (elem (table $t) (i32.const 1) func $deadA $live1 $deadMid $live2 $deadB)

 (func $deadA (param i64)
  (drop (i32.const 10))
 )
 ;; CHECK:      (elem $0 (i32.const 2) $live1 $deadMid $live2)

 ;; CHECK:      (export "caller" (func $caller))

 ;; CHECK:      (func $live1 (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 20)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $live1 (param i32)
  (drop (i32.const 20))
 )
 ;; CHECK:      (func $deadMid (type $1) (param $0 i64)
 ;; CHECK-NEXT:  (unreachable)
 ;; CHECK-NEXT: )
 (func $deadMid (param i64)
  (drop (i32.const 30))
 )
 ;; CHECK:      (func $live2 (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 40)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $live2 (param i32)
  (drop (i32.const 40))
 )
 (func $deadB (param f32)
  (drop (i32.const 50))
 )
 ;; CHECK:      (func $caller (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (call_indirect $t (type $0)
 ;; CHECK-NEXT:   (local.get $0)
 ;; CHECK-NEXT:   (i32.const 2)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $caller (export "caller") (param i32)
  (call_indirect (param i32) (local.get 0) (i32.const 2))
 )
)

(module
 ;; Nulls at the edges can be trimmed just like never-called functions:
 ;; writing a null is the same as not writing the slot at all.
 ;; CHECK:      (type $0 (func (param i32)))

 ;; CHECK:      (table $t 10 10 funcref)
 (table $t 10 10 funcref)

 (elem (table $t) (i32.const 3) funcref (ref.null func) (ref.func $live) (ref.null func))

 ;; CHECK:      (elem $0 (i32.const 4) $live)

 ;; CHECK:      (export "caller" (func $caller))

 ;; CHECK:      (func $live (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 10)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $live (param i32)
  (drop (i32.const 10))
 )
 ;; CHECK:      (func $caller (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (call_indirect $t (type $0)
 ;; CHECK-NEXT:   (local.get $0)
 ;; CHECK-NEXT:   (i32.const 4)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $caller (export "caller") (param i32)
  (call_indirect (param i32) (local.get 0) (i32.const 4))
 )
)

(module
 ;; A segment in which nothing can be called is removed entirely, along with
 ;; its functions. (It is in bounds, so no trap is lost by not applying it.)
 ;; CHECK:      (type $0 (func (param i32)))

 ;; CHECK:      (table $t 10 10 funcref)
 (table $t 10 10 funcref)

 (elem (table $t) (i32.const 1) func $dead1 $dead2)

 (func $dead1 (param i64)
  (drop (i32.const 10))
 )
 (func $dead2 (param f32)
  (drop (i32.const 20))
 )
 ;; CHECK:      (export "caller" (func $caller))

 ;; CHECK:      (func $caller (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (call_indirect $t (type $0)
 ;; CHECK-NEXT:   (local.get $0)
 ;; CHECK-NEXT:   (i32.const 2)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $caller (export "caller") (param i32)
  (call_indirect (param i32) (local.get 0) (i32.const 2))
 )
)

(module
 ;; The table is exported, so the outside can see and call anything in it: we
 ;; cannot trim.
 ;; CHECK:      (type $0 (func (param i32)))

 ;; CHECK:      (type $1 (func (param i64)))

 ;; CHECK:      (table $t 10 10 funcref)
 (table $t (export "table") 10 10 funcref)

 (elem (table $t) (i32.const 1) func $dead $live)

 ;; CHECK:      (elem $0 (i32.const 1) $dead $live)

 ;; CHECK:      (export "table" (table $t))

 ;; CHECK:      (export "caller" (func $caller))

 ;; CHECK:      (func $dead (type $1) (param $0 i64)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 10)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $dead (param i64)
  (drop (i32.const 10))
 )
 ;; CHECK:      (func $live (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 20)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $live (param i32)
  (drop (i32.const 20))
 )
 ;; CHECK:      (func $caller (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (call_indirect $t (type $0)
 ;; CHECK-NEXT:   (local.get $0)
 ;; CHECK-NEXT:   (i32.const 2)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $caller (export "caller") (param i32)
  (call_indirect (param i32) (local.get 0) (i32.const 2))
 )
)

(module
 ;; The table is imported: our writes to it are externally observable, and we
 ;; cannot trim.
 ;; CHECK:      (type $0 (func (param i32)))

 ;; CHECK:      (type $1 (func (param i64)))

 ;; CHECK:      (import "env" "table" (table $t 10 10 funcref))
 (import "env" "table" (table $t 10 10 funcref))

 (elem (table $t) (i32.const 1) func $dead $live)

 ;; CHECK:      (elem $0 (i32.const 1) $dead $live)

 ;; CHECK:      (export "caller" (func $caller))

 ;; CHECK:      (func $dead (type $1) (param $0 i64)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 10)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $dead (param i64)
  (drop (i32.const 10))
 )
 ;; CHECK:      (func $live (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 20)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $live (param i32)
  (drop (i32.const 20))
 )
 ;; CHECK:      (func $caller (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (call_indirect $t (type $0)
 ;; CHECK-NEXT:   (local.get $0)
 ;; CHECK-NEXT:   (i32.const 2)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $caller (export "caller") (param i32)
  (call_indirect (param i32) (local.get 0) (i32.const 2))
 )
)

(module
 ;; A table.get exists, which can observe the difference between a null and a
 ;; never-called function: we cannot trim.
 ;; CHECK:      (type $0 (func (param i32)))

 ;; CHECK:      (type $1 (func (param i64)))

 ;; CHECK:      (type $2 (func (result funcref)))

 ;; CHECK:      (table $t 10 10 funcref)
 (table $t 10 10 funcref)

 (elem (table $t) (i32.const 1) func $dead $live)

 ;; CHECK:      (elem $0 (i32.const 1) $dead $live)

 ;; CHECK:      (export "get" (func $get))

 ;; CHECK:      (export "caller" (func $caller))

 ;; CHECK:      (func $dead (type $1) (param $0 i64)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 10)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $dead (param i64)
  (drop (i32.const 10))
 )
 ;; CHECK:      (func $live (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 20)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $live (param i32)
  (drop (i32.const 20))
 )
 ;; CHECK:      (func $get (type $2) (result funcref)
 ;; CHECK-NEXT:  (table.get $t
 ;; CHECK-NEXT:   (i32.const 1)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $get (export "get") (result funcref)
  (table.get $t (i32.const 1))
 )
 ;; CHECK:      (func $caller (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (call_indirect $t (type $0)
 ;; CHECK-NEXT:   (local.get $0)
 ;; CHECK-NEXT:   (i32.const 2)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $caller (export "caller") (param i32)
  (call_indirect (param i32) (local.get 0) (i32.const 2))
 )
)

(module
 ;; The table has an initial value: not writing a slot would expose that value
 ;; rather than a null, so we cannot trim.
 ;; CHECK:      (type $0 (func (param i32)))

 ;; CHECK:      (type $1 (func (param i64)))

 ;; CHECK:      (table $t 10 10 funcref (ref.func $init))
 (table $t 10 10 funcref (ref.func $init))

 (elem (table $t) (i32.const 1) func $dead $live)

 ;; CHECK:      (elem $0 (i32.const 1) $dead $live)

 ;; CHECK:      (export "caller" (func $caller))

 ;; CHECK:      (func $init (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 5)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $init (param i32)
  (drop (i32.const 5))
 )
 ;; CHECK:      (func $dead (type $1) (param $0 i64)
 ;; CHECK-NEXT:  (unreachable)
 ;; CHECK-NEXT: )
 (func $dead (param i64)
  (drop (i32.const 10))
 )
 ;; CHECK:      (func $live (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 20)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $live (param i32)
  (drop (i32.const 20))
 )
 ;; CHECK:      (func $caller (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (call_indirect $t (type $0)
 ;; CHECK-NEXT:   (local.get $0)
 ;; CHECK-NEXT:   (i32.const 2)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $caller (export "caller") (param i32)
  (call_indirect (param i32) (local.get 0) (i32.const 2))
 )
)

(module
 ;; The segment extends out of bounds of the table (9 + 2 > 10), so it traps
 ;; at instantiation, and trimming would change that: we cannot trim.
 ;; CHECK:      (type $0 (func (param i32)))

 ;; CHECK:      (type $1 (func (param i64)))

 ;; CHECK:      (table $t 10 10 funcref)
 (table $t 10 10 funcref)

 (elem (table $t) (i32.const 9) func $dead $live)

 ;; CHECK:      (elem $0 (i32.const 9) $dead $live)

 ;; CHECK:      (export "caller" (func $caller))

 ;; CHECK:      (func $dead (type $1) (param $0 i64)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 10)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $dead (param i64)
  (drop (i32.const 10))
 )
 ;; CHECK:      (func $live (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 20)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $live (param i32)
  (drop (i32.const 20))
 )
 ;; CHECK:      (func $caller (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (call_indirect $t (type $0)
 ;; CHECK-NEXT:   (local.get $0)
 ;; CHECK-NEXT:   (i32.const 9)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $caller (export "caller") (param i32)
  (call_indirect (param i32) (local.get 0) (i32.const 9))
 )
)

(module
 ;; Two segments overlap, so a trimmed slot in one might really be written by
 ;; the other, in a particular order: we cannot trim either.
 ;; CHECK:      (type $0 (func (param i32)))

 ;; CHECK:      (type $1 (func (param i64)))

 ;; CHECK:      (type $2 (func (param f32)))

 ;; CHECK:      (table $t 10 10 funcref)
 (table $t 10 10 funcref)

 (elem (table $t) (i32.const 1) func $live $dead1)
 (elem (table $t) (i32.const 2) func $dead2 $live)

 ;; CHECK:      (elem $0 (i32.const 1) $live $dead1)

 ;; CHECK:      (elem $1 (i32.const 2) $dead2 $live)

 ;; CHECK:      (export "caller" (func $caller))

 ;; CHECK:      (func $dead1 (type $1) (param $0 i64)
 ;; CHECK-NEXT:  (unreachable)
 ;; CHECK-NEXT: )
 (func $dead1 (param i64)
  (drop (i32.const 10))
 )
 ;; CHECK:      (func $dead2 (type $2) (param $0 f32)
 ;; CHECK-NEXT:  (unreachable)
 ;; CHECK-NEXT: )
 (func $dead2 (param f32)
  (drop (i32.const 20))
 )
 ;; CHECK:      (func $live (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 30)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $live (param i32)
  (drop (i32.const 30))
 )
 ;; CHECK:      (func $caller (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (call_indirect $t (type $0)
 ;; CHECK-NEXT:   (local.get $0)
 ;; CHECK-NEXT:   (i32.const 1)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $caller (export "caller") (param i32)
  (call_indirect (param i32) (local.get 0) (i32.const 1))
 )
)

(module
 ;; A segment with a non-constant offset exists on this table. We cannot tell
 ;; what it overlaps, so we cannot trim anything on the entire table.
 ;; CHECK:      (type $0 (func (param i32)))

 ;; CHECK:      (type $1 (func (param i64)))

 ;; CHECK:      (import "env" "base" (global $base i32))
 (import "env" "base" (global $base i32))

 ;; CHECK:      (table $t 10 10 funcref)
 (table $t 10 10 funcref)

 (elem (table $t) (i32.const 1) func $dead $live)
 (elem (table $t) (global.get $base) func $live)

 ;; CHECK:      (elem $0 (i32.const 1) $dead $live)

 ;; CHECK:      (elem $1 (global.get $base) $live)

 ;; CHECK:      (export "caller" (func $caller))

 ;; CHECK:      (func $dead (type $1) (param $0 i64)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 10)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $dead (param i64)
  (drop (i32.const 10))
 )
 ;; CHECK:      (func $live (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 20)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $live (param i32)
  (drop (i32.const 20))
 )
 ;; CHECK:      (func $caller (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (call_indirect $t (type $0)
 ;; CHECK-NEXT:   (local.get $0)
 ;; CHECK-NEXT:   (i32.const 2)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $caller (export "caller") (param i32)
  (call_indirect (param i32) (local.get 0) (i32.const 2))
 )
)

(module
 ;; Two segments on the same table that do not overlap: both can be trimmed.
 ;; The second becomes entirely empty and is removed.
 ;; CHECK:      (type $0 (func (param i32)))

 ;; CHECK:      (table $t 10 10 funcref)
 (table $t 10 10 funcref)

 (elem (table $t) (i32.const 1) func $dead1 $live)
 (elem (table $t) (i32.const 6) func $dead2)

 (func $dead1 (param i64)
  (drop (i32.const 10))
 )
 (func $dead2 (param f32)
  (drop (i32.const 20))
 )
 ;; CHECK:      (elem $0 (i32.const 2) $live)

 ;; CHECK:      (export "caller" (func $caller))

 ;; CHECK:      (func $live (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 30)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $live (param i32)
  (drop (i32.const 30))
 )
 ;; CHECK:      (func $caller (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (call_indirect $t (type $0)
 ;; CHECK-NEXT:   (local.get $0)
 ;; CHECK-NEXT:   (i32.const 2)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $caller (export "caller") (param i32)
  (call_indirect (param i32) (local.get 0) (i32.const 2))
 )
)

(module
 ;; A 64-bit table: the offset is bumped with the proper type.
 ;; CHECK:      (type $0 (func (param i32)))

 ;; CHECK:      (table $t i64 10 10 funcref)
 (table $t i64 10 10 funcref)

 (elem (table $t) (i64.const 1) func $dead $live)

 (func $dead (param i64)
  (drop (i32.const 10))
 )
 ;; CHECK:      (elem $0 (i64.const 2) $live)

 ;; CHECK:      (export "caller" (func $caller))

 ;; CHECK:      (func $live (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (drop
 ;; CHECK-NEXT:   (i32.const 20)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $live (param i32)
  (drop (i32.const 20))
 )
 ;; CHECK:      (func $caller (type $0) (param $0 i32)
 ;; CHECK-NEXT:  (call_indirect $t (type $0)
 ;; CHECK-NEXT:   (local.get $0)
 ;; CHECK-NEXT:   (i64.const 2)
 ;; CHECK-NEXT:  )
 ;; CHECK-NEXT: )
 (func $caller (export "caller") (param i32)
  (call_indirect (param i32) (local.get 0) (i64.const 2))
 )
)

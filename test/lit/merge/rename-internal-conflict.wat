;; NOTE: Assertions have been generated by update_lit_checks.py --all-items and should not be edited.
;; RUN: wasm-merge %s first %s.second second -all -S -o - | filecheck %s

;; The global and export have name collisions with the side module, but even
;; worse, the alternative names we initially pick (adding _1) are themselves
;; also existing names.

(module
  ;; CHECK:      (global $classVTable (mut i32) (i32.const 1))
  (global $classVTable (mut i32) (i32.const 1))

  ;; CHECK:      (global $classVTable_2 (mut i32) (i32.const 2))

  ;; CHECK:      (global $classVTable_1 (mut i32) (i32.const 3))

  ;; CHECK:      (export "classVTable" (global $classVTable))
  (export "classVTable" (global $classVTable))
)

;; CHECK:      (export "classVTable_b" (global $classVTable_2))

;; CHECK:      (export "classVTable_1" (global $classVTable_1))

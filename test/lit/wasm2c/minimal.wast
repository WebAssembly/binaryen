;; CHECK-SOURCE-NEXT:     return 63 - r;
;; CHECK-SOURCE-NEXT:   }
;; CHECK-SOURCE-NEXT: #endif
;; CHECK-SOURCE-NEXT:   return 64;
;; CHECK-SOURCE-NEXT: }

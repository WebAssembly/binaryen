;; RUN: wasm2c %s -o %t.c
;; RUN: cat %t.h | filecheck %s --match-full-lines --strict-whitespace --check-prefixes CHECK-HEADER
;; RUN: cat %t.c | filecheck %s --match-full-lines --strict-whitespace -DHEADER_FILE=%basename_t.tmp.h --check-prefixes CHECK-SOURCE
(module)


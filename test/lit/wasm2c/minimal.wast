;; CHECK-SOURCE-NEXT: // MEMCHECK_GENERAL can be used for any memory
;; CHECK-SOURCE-NEXT: #define MEMCHECK_GENERAL(mem, a, t) \
;; CHECK-SOURCE-NEXT:   WASM_RT_CHECK_BASE(mem);          \

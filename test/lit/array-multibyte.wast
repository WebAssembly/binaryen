    (i32.store16 (type $i16_array) (local.get $a16) (i32.const 0) (i32.const 1))
    (drop (i32.load16_u (type $i16_array) (local.get $a16) (i32.const 0)))
    (i32.store (type $i32_array) (local.get $a32) (i32.const 0) (i32.const 2))
    (drop (i32.load (type $i32_array) (local.get $a32) (i32.const 0)))
    (i64.store (type $i64_array) (local.get $a64) (i32.const 0) (i64.const 3))
    (drop (i64.load (type $i64_array) (local.get $a64) (i32.const 0)))
    (f32.store (type $f32_array) (local.get $af32) (i32.const 0) (f32.const 4.0))
    (drop (f32.load (type $f32_array) (local.get $af32) (i32.const 0)))
    (f64.store (type $f64_array) (local.get $af64) (i32.const 0) (f64.const 5.0))
    (drop (f64.load (type $f64_array) (local.get $af64) (i32.const 0)))
    (v128.store (type $v128_array) (local.get $av) (i32.const 0) (v128.const i32x4 1 2 3 4))
    (drop (v128.load (type $v128_array) (local.get $av) (i32.const 0)))
  )

